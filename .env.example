# ============================================================
# Saman Prefab — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================

# ----------------------------
# Database
# ----------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/saman_prefab"

# ----------------------------
# API Server
# ----------------------------
API_PORT=4000
API_HOST=0.0.0.0
NODE_ENV=development

# ----------------------------
# JWT Authentication
# ----------------------------
JWT_ACCESS_SECRET="change-this-to-a-random-256-bit-secret-minimum-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-random-256-bit-secret-minimum-32-chars"

# ----------------------------
# Next.js Frontend
# ----------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ----------------------------
# Email (SMTP / SendGrid)
# ----------------------------
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@samanprefab.com"
ADMIN_EMAIL="admin@samanprefab.com"

# ----------------------------
# File Storage
# ----------------------------
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ----------------------------
# AI Writer — Groq (recommended, free tier)
# Sign up: https://console.groq.com → API Keys → Create Key
# Compatible with any OpenAI-format provider — just swap BASE_URL + MODEL
# ----------------------------
AGENTROUTER_API_KEY=""
AGENTROUTER_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"

# Other compatible providers:
# OpenAI:    BASE_URL=https://api.openai.com/v1          MODEL=gpt-4o-mini
# Mistral:   BASE_URL=https://api.mistral.ai/v1          MODEL=mistral-small-latest
# Together:  BASE_URL=https://api.together.xyz/v1        MODEL=mistralai/Mixtral-8x7B

# ----------------------------
# CRM Webhook (Optional)
# ----------------------------
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_SECRET=""
