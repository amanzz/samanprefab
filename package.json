{
  "name": "saman-prefab",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate --filter=@saman-prefab/db",
    "db:migrate": "turbo run db:migrate --filter=@saman-prefab/db",
    "db:studio": "turbo run db:studio --filter=@saman-prefab/db",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "e2e:codegen": "playwright codegen http://localhost:3000",
    "e2e:staging": "RUN_STAGING_TESTS=true playwright test --project=chromium-staging",
    "e2e:smoke": "playwright test smoke-tests --project=chromium-local",
    "e2e:full": "playwright test --project=chromium-local",
    "e2e:edge-cases": "playwright test edge-cases",
    "e2e:auth-edge": "playwright test auth-edge-cases",
    "e2e:monitoring": "playwright test production-monitoring",
    "e2e:network": "playwright test network-resilience",
    "e2e:business-flows": "playwright test business-flows",
    "e2e:chaos": "playwright test chaos-tests",
    "e2e:update-snapshots": "SNAPSHOT_UPDATE=approved playwright test --update-snapshots",
    "e2e:ci": "playwright test --reporter=github",
    "e2e:resilience": "playwright test chaos-tests network-resilience"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.9",
    "typescript": "^5.4.5"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3"
  }
}
